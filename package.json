{
  "name": "sanity-plugin-mermaid-content-model",
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "description": "Sanity Studio plugin that renders the content model as a Mermaid class diagram.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "mermaid",
    "content-model",
    "class-diagram",
    "schema"
  ],
  "homepage": "https://github.com/andybywire/sanity-plugin-mermaid-content-model#readme",
  "bugs": {
    "url": "https://github.com/andybywire/sanity-plugin-mermaid-content-model/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andybywire/sanity-plugin-mermaid-content-model.git"
  },
  "license": "MIT",
  "author": "Andy Fitzgerald",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "browserslist": "extends @sanity/browserslist-config",
  "scripts": {
    "build": "pkg-utils build --strict --check --clean",
    "watch": "pkg-utils watch --strict",
    "dev": "pnpm --filter studio dev",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "eslint .",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:studio-install": "node scripts/test-studio-install.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "sanity": "^5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.0.0",
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@sanity/pkg-utils": "^10",
    "@sanity/semantic-release-preset": "^6.0.0",
    "@sanity/types": "^5.30.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^5.30.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/ui": "^3.2.0",
    "mermaid": "^11.15.0",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  }
}
